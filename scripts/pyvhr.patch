+"""Vendored pyVHR package.
 
+This repository vendors a copy of `pyVHR` for rPPG / vitals extraction.
+
+Upstream `pyVHR` imports many optional, heavyweight dependencies at import time
+(e.g. `tensorflow`, `mediapipe`, `cupy`, `plotly`, Jupyter-only widgets). That
+behavior makes `import pyVHR` fragile in typical webapp/server environments.
+
+Keep this `__init__` intentionally lightweight and let callers import the
+submodules they need.
+"""
+
+from __future__ import annotations
+
+__all__: list[str] = []
